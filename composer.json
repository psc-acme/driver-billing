{
    "name": "psc-acme/driver-billing",
    "description": "Package driver-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DriverBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/cache": "^7.0",
        "brick/date-time": "^0.7.1",
        "psr/log": "^3.0",
        "league/commonmark": "^2.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "vimeo/psalm": "^5.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}